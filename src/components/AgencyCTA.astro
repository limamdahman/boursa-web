---
import { getLang, useTranslations } from '@/i18n/translations';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const stats = [
  { num: '142', label: t('agency.stat.partners') },
  { num: '2 470', label: t('agency.stat.listings') },
  { num: '12k+', label: t('agency.stat.visitors') },
];
---

<section class="py-12">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="bg-[var(--color-text-1)] rounded-2xl p-8 lg:p-10 grid md:grid-cols-[1.5fr_1fr] gap-8 items-center">
      <div>
        <h2 class="text-2xl lg:text-3xl font-extrabold text-white leading-tight mb-2">
          {t('agency.cta.title')}
        </h2>
        <p class="text-sm text-white/70 max-w-xl">
          {t('agency.cta.subtitle')}
        </p>

        <div class="mt-6 grid grid-cols-3 gap-4 max-w-md">
          {stats.map((stat) => (
            <div>
              <div class="text-xl font-extrabold text-[var(--color-brand-500)] ltr-numbers">
                {stat.num}
              </div>
              <div class="text-[10px] font-semibold text-white/60 uppercase tracking-wider">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="md:text-end">
        <a
          href={`/${lang}/agences/inscription`}
          class="inline-flex items-center gap-2 bg-[var(--color-brand-600)] hover:bg-[var(--color-brand-700)] text-white font-extrabold text-sm px-6 py-3.5 rounded-lg transition-colors"
        >
          {t('agency.cta.button')}
          <i class={`fa-solid fa-arrow-${lang === 'ar' ? 'left' : 'right'} text-xs`}></i>
        </a>
      </div>
    </div>
  </div>
</section>

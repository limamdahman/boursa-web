---
import { useTranslations, getLang } from "@/i18n/translations";
interface Props { agency: any; }
const { agency } = Astro.props;
const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
const cityName = lang === "ar" && agency.city?.name_ar ? agency.city.name_ar : agency.city?.name_fr;
const detailUrl = "/" + lang + "/agences/" + agency.slug;
const initials = agency.name.split(" ").slice(0, 2).map((w: string) => w[0]).join("").toUpperCase();
const tier = agency.subscription_tier ?? "free";
const isBusiness = tier === "business";
const isPro = tier === "pro";
const cardBorder = isBusiness ? "2px solid #F59E0B" : "1px solid #E2E8F0";
const tierChipBg = isBusiness ? "linear-gradient(135deg,#F59E0B,#D97706)" : isPro ? "#EFF6FF" : "#F1F5F9";
const tierChipColor = isBusiness ? "white" : isPro ? "#2563EB" : "#94A3B8";
const tierChipLabel = isBusiness ? "BUSINESS" : isPro ? "PRO" : (lang === "ar" ? "مجاني" : "GRATUIT");
const badgeSvgGold = "<svg width='16' height='16' viewBox='0 0 24 24' fill='#F59E0B' xmlns='http://www.w3.org/2000/svg'><path d='M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.818-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.437 2.25c-.415-.165-.866-.25-1.336-.25-2.11 0-3.818 1.79-3.818 4 0 .494.083.964.237 1.4-1.272.65-2.147 2.018-2.147 3.6 0 1.495.782 2.798 1.942 3.486-.02.17-.032.34-.032.514 0 2.21 1.708 4 3.818 4 .47 0 .92-.086 1.335-.25.62 1.334 1.926 2.25 3.437 2.25 1.512 0 2.818-.916 3.437-2.25.415.163.865.248 1.336.248 2.11 0 3.818-1.79 3.818-4 0-.174-.012-.344-.033-.513 1.158-.687 1.943-1.99 1.943-3.484zm-6.616-3.334l-4.334 6.5c-.145.217-.382.334-.625.334-.143 0-.288-.04-.416-.126l-.115-.094-2.415-2.415c-.293-.293-.293-.768 0-1.06s.768-.294 1.06 0l1.77 1.767 3.825-5.74c.23-.345.696-.436 1.04-.207.346.23.44.696.21 1.04z'/></svg>";
const badgeSvgGreen = "<svg width='16' height='16' viewBox='0 0 24 24' fill='#16A34A' xmlns='http://www.w3.org/2000/svg'><path d='M22.5 12.5c0-1.58-.875-2.95-2.148-3.6.154-.435.238-.905.238-1.4 0-2.21-1.71-3.998-3.818-3.998-.47 0-.92.084-1.336.25C14.818 2.415 13.51 1.5 12 1.5s-2.816.917-3.437 2.25c-.415-.165-.866-.25-1.336-.25-2.11 0-3.818 1.79-3.818 4 0 .494.083.964.237 1.4-1.272.65-2.147 2.018-2.147 3.6 0 1.495.782 2.798 1.942 3.486-.02.17-.032.34-.032.514 0 2.21 1.708 4 3.818 4 .47 0 .92-.086 1.335-.25.62 1.334 1.926 2.25 3.437 2.25 1.512 0 2.818-.916 3.437-2.25.415.163.865.248 1.336.248 2.11 0 3.818-1.79 3.818-4 0-.174-.012-.344-.033-.513 1.158-.687 1.943-1.99 1.943-3.484zm-6.616-3.334l-4.334 6.5c-.145.217-.382.334-.625.334-.143 0-.288-.04-.416-.126l-.115-.094-2.415-2.415c-.293-.293-.293-.768 0-1.06s.768-.294 1.06 0l1.77 1.767 3.825-5.74c.23-.345.696-.436 1.04-.207.346.23.44.696.21 1.04z'/></svg>";
---
<a href={detailUrl}
  style={"display:block;background:white;border:" + cardBorder + ";border-radius:12px;padding:20px;text-decoration:none;transition:all 0.15s;"}
  onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(22,163,74,0.1)'"
  onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'"
>
  <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:14px;">
    <div style="width:56px;height:56px;background:#0F172A;border-radius:12px;display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:18px;flex-shrink:0;overflow:hidden;">
      {agency.logo_url ? <img src={agency.logo_url} alt={agency.name} style="width:100%;height:100%;object-fit:cover;" /> : <span>{initials}</span>}
    </div>
    <div style="flex:1;min-width:0;">
      <div style="display:flex;align-items:center;gap:5px;margin-bottom:6px;flex-wrap:wrap;">
        <h3 style="font-size:16px;font-weight:800;color:#0F172A;margin:0;">{agency.name}</h3>
        {isBusiness ? (<Fragment set:html={badgeSvgGold} />) : (isPro || agency.is_verified) ? (<Fragment set:html={badgeSvgGreen} />) : null}
      </div>
      <span style={"display:inline-block;font-size:10px;font-weight:700;padding:2px 7px;border-radius:100px;background:" + tierChipBg + ";color:" + tierChipColor}>
        {tierChipLabel}
      </span>
    </div>
  </div>
  <div style="display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid #E2E8F0;">
    <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:#475569;">
      <i class="fa-solid fa-location-dot" style="font-size:11px;color:#16A34A"></i>
      <span>{cityName || "—"}</span>
    </div>
    <div style="display:flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#0F172A;">
      <i class="fa-solid fa-car" style="font-size:11px;color:#16A34A"></i>
      <span dir="ltr">{agency.vehicles_count}</span>
      <span style="font-size:11px;color:#64748B;font-weight:500;">{lang === "ar" ? "سيارة" : "véh."}</span>
    </div>
  </div>
</a>

---
import { listVehicles } from '@/lib/api';
import { getLang, useTranslations } from '@/i18n/translations';

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

interface LifestyleCat {
  slug: string;
  titleKey: string;
  tagsKey: string;
  badge: string;
  badgeColor: string;
  icon: string;
  params: Record<string, string>;
}

const categories: LifestyleCat[] = [
  {
    slug: 'famille',
    titleKey: 'lifestyle.family.title',
    tagsKey: 'lifestyle.family.tags',
    badge: 'lifestyle.family.badge',
    badgeColor: '#16A34A',
    icon: 'house-chimney',
    params: { body_type: 'suv', year_min: '2018' },
  },
  {
    slug: 'premium',
    titleKey: 'lifestyle.premium.title',
    tagsKey: 'lifestyle.premium.tags',
    badge: 'lifestyle.premium.badge',
    badgeColor: '#0F172A',
    icon: 'crown',
    params: { price_min: '3000000' },
  },
  {
    slug: 'premier-achat',
    titleKey: 'lifestyle.first.title',
    tagsKey: 'lifestyle.first.tags',
    badge: 'lifestyle.first.badge',
    badgeColor: '#D97706',
    icon: 'graduation-cap',
    params: { price_max: '800000' },
  },
  {
    slug: 'pickup',
    titleKey: 'lifestyle.pickup.title',
    tagsKey: 'lifestyle.pickup.tags',
    badge: 'lifestyle.pickup.badge',
    badgeColor: '#15803D',
    icon: 'mountain',
    params: { body_type: 'pickup' },
  },
];

// Charge le premier véhicule de chaque catégorie pour récupérer la cover
async function loadCategoryData(cat: LifestyleCat) {
  try {
    const params: Record<string, any> = { ...cat.params, per_page: 5 };
    const result = await listVehicles(params);
    const first = result?.data?.[0];
    return {
      ...cat,
      cover: first?.cover_image ?? null,
      count: result?.meta?.total ?? 0,
      minPrice: first?.price_mru ?? 0,
    };
  } catch (e) {
    return { ...cat, cover: null, count: 0, minPrice: 0 };
  }
}

const enriched = await Promise.all(categories.map(loadCategoryData));

const fmtPrice = (n: number) => {
  if (n >= 1000000) return (n / 1000000).toFixed(1).replace('.0', '') + 'M';
  if (n >= 1000) return Math.round(n / 1000) + 'K';
  return String(n);
};
---

<section style="padding: 60px 24px; background: #F8FAFC;">
  <div style="max-width: 1280px; margin: 0 auto;">

    <div style="display: flex; align-items: flex-end; margin-bottom: 28px;">
      <div>
        <h2 style="font-size: 28px; font-weight: 800; letter-spacing: -0.03em; color: #0F172A; margin: 0 0 4px;">
          {t('lifestyle.title')}
        </h2>
        <p style="font-size: 14px; color: #475569; margin: 0;">
          {t('lifestyle.subtitle')}
        </p>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;" class="lifestyle-grid-responsive">
      {enriched.map((cat) => {
        const cardStyle = "background: #FFFFFF; border: 1px solid #E2E8F0; border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; display: block; transition: all 0.2s; cursor: pointer;";
        const imgWrapStyle = "aspect-ratio: 4/3; background: linear-gradient(135deg, #1f2937, #0f172a); position: relative; overflow: hidden;";
        const badgeStyle = "position: absolute; top: 10px; left: 10px; color: white; font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 4px; letter-spacing: 0.04em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 5px; background: " + cat.badgeColor + ";";
        const countStyle = "position: absolute; bottom: 10px; left: 10px; background: rgba(0,0,0,0.6); color: white; font-family: 'JetBrains Mono', monospace; font-size: 9px; padding: 3px 8px; border-radius: 3px;";
        const bodyStyle = "padding: 14px;";
        const titleStyle = "font-size: 16px; font-weight: 800; letter-spacing: -0.02em; margin: 0 0 4px; color: #0F172A;";
        const descStyle = "font-size: 12px; color: #475569; line-height: 1.4; margin-bottom: 10px;";
        const ctaStyle = "display: flex; align-items: center; justify-content: space-between; margin-top: 12px; padding-top: 12px; border-top: 1px solid #E2E8F0;";
        const fromStyle = "font-size: 11px; color: #64748B;";
        const priceStyle = "color: #D97706; font-size: 13px; font-weight: 800;";
        const arrowStyle = "width: 28px; height: 28px; background: #F0FDF4; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #16A34A; font-size: 11px;";
        const href = "/" + lang + "/vehicules/lifestyle/" + cat.slug;
        return (
          <a href={href} class="lifestyle-card" style={cardStyle}>
            <div style={imgWrapStyle}>
              {cat.cover ? (
                <img src={cat.cover} alt={t(cat.titleKey)} style="width: 100%; height: 100%; object-fit: cover;" />
              ) : (
                <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #1f2937, #0f172a);"></div>
              )}
              <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.4) 100%);"></div>
              <span style={badgeStyle}>
                <i class={"fa-solid fa-" + cat.icon} style="font-size: 9px"></i>
                {t(cat.badge)}
              </span>
              <span style={countStyle}>{cat.count} {t('lifestyle.vehiclesShort')}</span>
            </div>
            <div style={bodyStyle}>
              <h3 style={titleStyle}>{t(cat.titleKey)}</h3>
              <p style={descStyle}>{t(cat.tagsKey)}</p>
              <div style={ctaStyle}>
                <div style={fromStyle}>
                  {t('lifestyle.fromPrice')} <span style={priceStyle}>{fmtPrice(cat.minPrice)} MRU</span>
                </div>
                <div style={arrowStyle}>
                  <i class={"fa-solid fa-arrow-" + (lang === 'ar' ? 'left' : 'right')}></i>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .lifestyle-card:hover {
    border-color: #16A34A !important;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08) !important;
    transform: translateY(-2px);
  }
  @media (max-width: 1024px) {
    .lifestyle-grid-responsive {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 640px) {
    .lifestyle-grid-responsive {
      grid-template-columns: repeat(1, 1fr) !important;
    }
  }
</style>

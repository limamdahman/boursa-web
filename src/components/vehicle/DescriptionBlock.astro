---
import { useTranslations, getLang } from '@/i18n/translations';

interface Props {
  vehicle: any;
}

const { vehicle } = Astro.props;
const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const description = lang === 'ar' && vehicle.description_ar ? vehicle.description_ar : vehicle.description_fr;

if (!description) return null;
---

<div style="background: white; border-radius: 12px; border: 1px solid #E2E8F0; padding: 24px;">
  <h2 style="font-size: 16px; font-weight: 800; color: #0F172A; margin: 0 0 14px; display: flex; align-items: center; gap: 8px;">
    <i class="fa-solid fa-quote-left" style="font-size: 12px; color: #16A34A"></i>
    {t('vehicle.description')}
  </h2>
  <p style="font-size: 14px; color: #475569; line-height: 1.7; margin: 0; white-space: pre-line;">
    {description}
  </p>
</div>

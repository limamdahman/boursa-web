---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
export const prerender = false;
---
<Layout title="الأسعار — بورصة">
  <Header />
  <section style="background: white; border-bottom: 1px solid #E2E8F0;" dir="rtl">
    <div style="max-width: 1400px; margin: 0 auto; padding: 32px 24px;">
      <h1 style="font-size: 28px; font-weight: 800; color: #0F172A; margin: 0 0 6px;">أسعار الوكالات</h1>
      <p style="font-size: 14px; color: #475569; margin: 0;">اختر الباقة المناسبة لنشاطك</p>
    </div>
  </section>
  
      <section style="background:white; padding:64px 24px;" dir="rtl">
        <div style="max-width:1000px; margin:0 auto;">
          <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:20px;" class="pricing-grid">
            <div style="border:1px solid #E2E8F0; border-radius:16px; padding:28px; background:white;">
              <div style="font-size:13px; font-weight:700; color:#64748B; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">مجاني</div>
              <div style="font-size:36px; font-weight:800; color:#0F172A; margin-bottom:4px;" dir="ltr">0 <span style="font-size:14px; font-weight:500; color:#64748B;">أوقية/شهر</span></div>
              <p style="font-size:13px; color:#64748B; margin:0 0 20px; line-height:1.5;">للبدء واختبار المنصة</p>
              <div style="border-top:1px solid #E2E8F0; padding-top:20px; display:flex; flex-direction:column; gap:12px; margin-bottom:28px;">
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> حتى 10 إعلانات</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> صفحة وكالة عامة</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> تواصل واتساب</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#94A3B8;"><i class="fa-solid fa-xmark" style="color:#CBD5E1; flex-shrink:0;"></i> إحصاءات متقدمة</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#94A3B8;"><i class="fa-solid fa-xmark" style="color:#CBD5E1; flex-shrink:0;"></i> إبراز الإعلانات</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#94A3B8;"><i class="fa-solid fa-xmark" style="color:#CBD5E1; flex-shrink:0;"></i> محادثة العملاء</div>
              </div>
              <a href="/ar/agences" style="display:block; text-align:center; background:#F1F5F9; color:#374151; border-radius:8px; padding:12px; font-weight:700; text-decoration:none; font-size:14px;">ابدأ مجاناً</a>
            </div>
            <div style="border:2px solid #16A34A; border-radius:16px; padding:28px; background:white; position:relative;">
              <div style="position:absolute; top:-12px; right:50%; transform:translateX(50%); background:#16A34A; color:white; padding:4px 16px; border-radius:100px; font-size:12px; font-weight:700; white-space:nowrap;">الأكثر شيوعاً</div>
              <div style="font-size:13px; font-weight:700; color:#15803D; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">احترافي</div>
              <div style="font-size:36px; font-weight:800; color:#0F172A; margin-bottom:4px;">حسب الطلب</div>
              <p style="font-size:13px; color:#64748B; margin:0 0 20px; line-height:1.5;">للوكالات النشطة التي تريد النمو</p>
              <div style="border-top:1px solid #E2E8F0; padding-top:20px; display:flex; flex-direction:column; gap:12px; margin-bottom:28px;">
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> إعلانات غير محدودة</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> صفحة وكالة مميزة</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> واتساب + مكالمات</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> إحصاءات متقدمة</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#94A3B8;"><i class="fa-solid fa-xmark" style="color:#CBD5E1; flex-shrink:0;"></i> إبراز أولوية</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#374151;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> محادثة العملاء</div>
              </div>
              <a href="https://wa.me/22240000000?text=Bonjour+Boursa,+je+souhaite+passer+au+plan+Pro" target="_blank" style="display:block; text-align:center; background:#16A34A; color:white; border-radius:8px; padding:12px; font-weight:700; text-decoration:none; font-size:14px;">طلب عرض سعر</a>
            </div>
            <div style="border:1px solid #E2E8F0; border-radius:16px; padding:28px; background:#0F172A;">
              <div style="font-size:13px; font-weight:700; color:#64748B; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">أعمال</div>
              <div style="font-size:36px; font-weight:800; color:white; margin-bottom:4px;">حسب الطلب</div>
              <p style="font-size:13px; color:#64748B; margin:0 0 20px; line-height:1.5;">للمجموعات الكبرى والوكلاء الرسميين</p>
              <div style="border-top:1px solid #1E293B; padding-top:20px; display:flex; flex-direction:column; gap:12px; margin-bottom:28px;">
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#E2E8F0;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> كل مزايا الاحترافي</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#E2E8F0;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> إبراز أولوية</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#E2E8F0;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> شارة "شريك رسمي"</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#E2E8F0;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> مدير حساب مخصص</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#E2E8F0;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> تكامل API المخزون</div>
                <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#E2E8F0;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> تقارير شهرية</div>
              <div style="display:flex; gap:10px; align-items:center; font-size:14px; color:#E2E8F0;"><i class="fa-solid fa-check" style="color:#16A34A; flex-shrink:0;"></i> إعلانات Facebook مجانية 🎁</div>
              </div>
              <a href="https://wa.me/22240000000?text=Bonjour+Boursa,+je+souhaite+passer+au+plan+Pro" target="_blank" style="display:block; text-align:center; background:#16A34A; color:white; border-radius:8px; padding:12px; font-weight:700; text-decoration:none; font-size:14px;">تواصل معنا</a>
            </div>
          </div>
        </div>
      </section>
      <style>@media (max-width: 768px) { .pricing-grid { grid-template-columns: 1fr !important; } }</style>
    
  <Footer />
</Layout>

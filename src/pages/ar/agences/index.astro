---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import AgencyCard from '@/components/AgencyCard.astro';
import { listAgencies } from '@/lib/api';
import { getLang, useTranslations } from '@/i18n/translations';
export const prerender = false;
const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);
let agencies: any[] = [];
let total = 0;
try {
  const result = await listAgencies({ per_page: 24 });
  agencies = result?.data ?? [];
  total = result?.meta?.total ?? agencies.length;
} catch (err) {
  console.error('Erreur chargement agences:', err);
}
---
<Layout title="الوكالات الشريكة">
  <Header active="agences" />

  <!-- Hero -->
  <section style="background: white; border-bottom: 1px solid #E2E8F0;" dir="rtl">
    <div style="max-width: 1400px; margin: 0 auto; padding: 32px 24px;">
      <h1 style="font-size: 28px; font-weight: 800; color: #0F172A; margin: 0 0 6px;">
        الوكالات الشريكة
      </h1>
      <p style="font-size: 14px; color: #475569; margin: 0;">
        اكتشف جميع الوكالات الموثوقة في بورصة موريتانيا
      </p>
      <div style="margin-top: 16px; display: inline-flex; align-items: center; gap: 8px; background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 100px; padding: 6px 14px;">
        <i class="fa-solid fa-building" style="font-size: 12px; color: #16A34A"></i>
        <span style="font-size: 13px; font-weight: 700; color: #15803D;">
          <span dir="ltr">{total}</span> وكالة
        </span>
      </div>
    </div>
  </section>

  <!-- Grille agences -->
  <section style="padding: 32px 24px; background: #F8FAFC; min-height: 40vh;" dir="rtl">
    <div style="max-width: 1400px; margin: 0 auto;">
      {agencies.length === 0 ? (
        <div style="text-align: center; padding: 80px 20px; background: white; border-radius: 12px; border: 1px solid #E2E8F0;">
          <i class="fa-solid fa-building-circle-exclamation" style="font-size: 48px; color: #CBD5E1; margin-bottom: 16px"></i>
          <h2 style="font-size: 18px; font-weight: 800; color: #0F172A; margin: 0">
            لا توجد وكالات حاليا
          </h2>
        </div>
      ) : (
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;" class="agencies-grid">
          {agencies.map((a) => <AgencyCard agency={a} />)}
        </div>
      )}
    </div>
  </section>

  <!-- CTA Devenir agence -->
  <section style="background: #0F172A; padding: 64px 24px;" dir="rtl">
    <div style="max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap;">
      <div style="flex: 1; min-width: 280px;">
        <h2 style="font-size: 28px; font-weight: 800; color: white; margin: 0 0 12px;">
          هل أنت وكالة سيارات؟
        </h2>
        <p style="font-size: 15px; color: #94A3B8; margin: 0 0 24px; line-height: 1.8;">
          انشر مخزونك أمام أكثر من 12,000 مشتري شهرياً.<br/>
          أدوات احترافية، إحصاءات فورية، عملاء مؤهلون.
        </p>
        <div style="display: flex; gap: 32px; flex-wrap: wrap;">
          <div>
            <div style="font-size: 24px; font-weight: 800; color: #16A34A;" dir="ltr">142</div>
            <div style="font-size: 12px; color: #64748B; text-transform: uppercase; letter-spacing: 0.05em;">وكالة شريكة</div>
          </div>
          <div>
            <div style="font-size: 24px; font-weight: 800; color: #16A34A;" dir="ltr">2 470</div>
            <div style="font-size: 12px; color: #64748B;">إعلان نشط</div>
          </div>
          <div>
            <div style="font-size: 24px; font-weight: 800; color: #16A34A;" dir="ltr">12k+</div>
            <div style="font-size: 12px; color: #64748B;">زيارة / شهر</div>
          </div>
        </div>
      </div>
      <div>
        <button
          onclick="document.getElementById('modal-agence').style.display='flex'"
          style="background: #16A34A; color: white; border: none; border-radius: 10px; padding: 16px 32px; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 10px; white-space: nowrap;"
        >
          <i class="fa-solid fa-arrow-left"></i>
          انضم كوكالة شريكة
        </button>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background: white; padding: 64px 24px;" dir="rtl">
    <div style="max-width: 800px; margin: 0 auto;">
      <h2 style="font-size: 24px; font-weight: 800; color: #0F172A; text-align: center; margin: 0 0 8px;">
        الأسئلة الشائعة
      </h2>
      <p style="font-size: 14px; color: #475569; text-align: center; margin: 0 0 40px;">
        كل ما تحتاج معرفته قبل الانضمام إلى بورصة
      </p>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            كيف أصبح وكالة شريكة في بورصة؟
            <i class="fa-solid fa-chevron-down faq-icon"></i>
          </button>
          <div class="faq-a">
            اضغط على "انضم كوكالة شريكة"، واملأ نموذج الطلب. سيتواصل معك فريقنا خلال 24 ساعة للتحقق من ملفك وتفعيل حسابك الاحترافي.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            ما هي الأسعار والباقات المتاحة؟
            <i class="fa-solid fa-chevron-down faq-icon"></i>
          </button>
          <div class="faq-a">
            تقدم بورصة باقات متعددة تناسب حجم وكالتك: مجاني (حتى 5 إعلانات)، احترافي (إعلانات غير محدودة + إحصاءات)، أعمال (كل شيء مشمول + إبراز الإعلانات). تواصل معنا للحصول على عرض خاص.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            كيف يتم التحقق من الوكالة؟
            <i class="fa-solid fa-chevron-down faq-icon"></i>
          </button>
          <div class="faq-a">
            يتحقق فريقنا يدوياً من كل وكالة: الوجود القانوني (السجل التجاري)، الموقع الجغرافي، وهوية المسؤول. بعد التحقق، تظهر على وكالتك شارة "موثقة" تراها جميع الأطراف.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            كم عدد السيارات التي يمكنني نشرها؟
            <i class="fa-solid fa-chevron-down faq-icon"></i>
          </button>
          <div class="faq-a">
            عدد الإعلانات يعتمد على باقتك. الباقة المجانية محدودة بـ 5 سيارات نشطة. الباقتان الاحترافية والأعمال غير محدودتان. يمكنك ترقية باقتك في أي وقت من لوحة التحكم.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            ما هي الأدوات المقدمة للوكالات؟
            <i class="fa-solid fa-chevron-down faq-icon"></i>
          </button>
          <div class="faq-a">
            لوحة تحكم مع إحصاءات فورية (المشاهدات، العملاء، معدل التحويل)، إدارة مخزون السيارات، استقبال العملاء المحتملين (واتساب، مكالمات، رسائل)، وصفحة وكالة عامة مخصصة على بورصة.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">
            كيف يتواصل المشترون معي؟
            <i class="fa-solid fa-chevron-down faq-icon"></i>
          </button>
          <div class="faq-a">
            يمكن للمشترين التواصل معك مباشرة عبر واتساب، الهاتف، أو الرسائل من كل إعلان. جميع العملاء مجمعون في لوحة التحكم لمتابعة سهلة.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modale demande agence -->
  <div id="modal-agence" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center; padding:20px;" dir="rtl">
    <div style="background:white; border-radius:16px; padding:32px; width:100%; max-width:500px; position:relative; max-height:90vh; overflow-y:auto;">
      <button onclick="document.getElementById('modal-agence').style.display='none'" style="position:absolute; top:16px; left:16px; background:none; border:none; font-size:20px; cursor:pointer; color:#64748B;">
        <i class="fa-solid fa-xmark"></i>
      </button>
      <h3 style="font-size: 20px; font-weight: 800; color: #0F172A; margin: 0 0 6px;">
        طلب انضمام وكالة
      </h3>
      <p style="font-size: 13px; color: #64748B; margin: 0 0 24px;">
        سيتواصل معك فريقنا خلال 24 ساعة
      </p>
      <div id="form-agence">
        <div style="margin-bottom: 16px;">
          <label style="display:block; font-size:13px; font-weight:600; color:#374151; margin-bottom:6px;">اسم الوكالة *</label>
          <input id="ag-name" type="text" placeholder="مثال: تيفراغ أوتو" style="width:100%; padding:10px 14px; border:1px solid #D1D5DB; border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;" />
        </div>
        <div style="margin-bottom: 16px;">
          <label style="display:block; font-size:13px; font-weight:600; color:#374151; margin-bottom:6px;">الهاتف / واتساب *</label>
          <input id="ag-phone" type="tel" placeholder="22240000000" dir="ltr" style="width:100%; padding:10px 14px; border:1px solid #D1D5DB; border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;" />
        </div>
        <div style="margin-bottom: 16px;">
          <label style="display:block; font-size:13px; font-weight:600; color:#374151; margin-bottom:6px;">المدينة</label>
          <input id="ag-city" type="text" placeholder="مثال: نواكشوط" style="width:100%; padding:10px 14px; border:1px solid #D1D5DB; border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;" />
        </div>
        <div style="margin-bottom: 24px;">
          <label style="display:block; font-size:13px; font-weight:600; color:#374151; margin-bottom:6px;">رسالة (اختياري)</label>
          <textarea id="ag-message" rows="3" placeholder="أخبرنا عن وكالتك..." style="width:100%; padding:10px 14px; border:1px solid #D1D5DB; border-radius:8px; font-size:14px; outline:none; resize:none; box-sizing:border-box;"></textarea>
        </div>
        <button onclick="submitAgenceRequest()" style="width:100%; background:#16A34A; color:white; border:none; border-radius:10px; padding:14px; font-size:15px; font-weight:700; cursor:pointer;">
          إرسال الطلب
        </button>
      </div>
      <div id="form-agence-success" style="display:none; text-align:center; padding:20px 0;">
        <i class="fa-solid fa-circle-check" style="font-size:48px; color:#16A34A; margin-bottom:16px;"></i>
        <h4 style="font-size:18px; font-weight:800; color:#0F172A; margin:0 0 8px;">تم إرسال الطلب!</h4>
        <p style="font-size:14px; color:#475569; margin:0;">سيتواصل معك فريقنا على الرقم المدخل خلال 24 ساعة.</p>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  @media (max-width: 1024px) {
    .agencies-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 640px) {
    .agencies-grid { grid-template-columns: 1fr !important; }
  }
  .faq-list { display: flex; flex-direction: column; gap: 8px; }
  .faq-item { border: 1px solid #E2E8F0; border-radius: 10px; overflow: hidden; }
  .faq-q {
    width: 100%; background: white; border: none; padding: 18px 20px;
    font-size: 15px; font-weight: 600; color: #0F172A; text-align: right;
    cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 16px;
  }
  .faq-q:hover { background: #F8FAFC; }
  .faq-q.open { background: #F0FDF4; color: #15803D; }
  .faq-q.open .faq-icon { transform: rotate(180deg); color: #16A34A; }
  .faq-icon { transition: transform 0.2s; flex-shrink: 0; }
  .faq-a { display: none; padding: 0 20px 18px; font-size: 14px; color: #475569; line-height: 1.8; }
  .faq-a.open { display: block; }
</style>

<script>
  function toggleFaq(btn: HTMLButtonElement) {
    const item = btn.closest('.faq-item') as HTMLElement;
    const answer = item.querySelector('.faq-a') as HTMLElement;
    const isOpen = btn.classList.contains('open');
    document.querySelectorAll('.faq-q').forEach(b => b.classList.remove('open'));
    document.querySelectorAll('.faq-a').forEach(a => a.classList.remove('open'));
    if (!isOpen) {
      btn.classList.add('open');
      answer.classList.add('open');
    }
  }

  async function submitAgenceRequest() {
    const name = (document.getElementById('ag-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('ag-phone') as HTMLInputElement).value.trim();
    const city = (document.getElementById('ag-city') as HTMLInputElement).value.trim();
    const message = (document.getElementById('ag-message') as HTMLTextAreaElement).value.trim();
    if (!name || !phone) {
      alert('يرجى ملء اسم الوكالة والهاتف.');
      return;
    }
    const btn = document.querySelector('#form-agence button') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'جار الإرسال...';
    try {
      await fetch(import.meta.env.PUBLIC_API_URL + '/agency-requests', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone, city, message }),
      });
    } catch {}
    document.getElementById('form-agence')!.style.display = 'none';
    document.getElementById('form-agence-success')!.style.display = 'block';
  }

  (window as any).toggleFaq = toggleFaq;
  (window as any).submitAgenceRequest = submitAgenceRequest;
</script>

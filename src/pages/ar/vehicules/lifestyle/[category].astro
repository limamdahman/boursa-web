---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import VehicleCard from '@/components/VehicleCard.astro';
import { listVehicles } from '@/lib/api';
import { getLang, useTranslations } from '@/i18n/translations';

export const prerender = false;

const lang = getLang(Astro.currentLocale);
const t = useTranslations(lang);

const { category } = Astro.params;

const CATEGORY_FILTERS: Record<string, Record<string, string>> = {
  'famille': { body_type: 'suv', year_min: '2018' },
  'premium': { price_min: '3000000' },
  'premier-achat': { price_max: '800000' },
  'pickup': { body_type: 'pickup' },
};

const CATEGORY_TITLES: Record<string, string> = {
  'famille': t('lifestyle.family.title'),
  'premium': t('lifestyle.premium.title'),
  'premier-achat': t('lifestyle.first.title'),
  'pickup': t('lifestyle.pickup.title'),
};

if (!category || !CATEGORY_FILTERS[category]) {
  return Astro.redirect(`/${lang}/vehicules`);
}

const params = { ...CATEGORY_FILTERS[category], per_page: 20 };
const listing = await listVehicles(params).catch(() => null);
const vehicles = listing?.data ?? [];
const total = listing?.meta?.total ?? 0;
const title = CATEGORY_TITLES[category];
---

<Layout title={title}>
  <Header active="vehicules" />

  <section style="background: white; border-bottom: 1px solid #E2E8F0;">
    <div style="max-width: 1280px; margin: 0 auto; padding: 28px 24px;">
      <a href={"/" + lang + "/"} style="font-size: 12px; color: #475569; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 12px;">
        <i class={"fa-solid fa-arrow-" + (lang === 'ar' ? 'right' : 'left')} style="font-size: 11px"></i>
        {t('vehicle.backToResults')}
      </a>
      <h1 style="font-family: 'Inter Tight', 'Source Sans 3', sans-serif; font-size: 32px; font-weight: 800; letter-spacing: -0.03em; color: #0F172A; margin: 0 0 4px;">
        {title}
      </h1>
      <p style="font-size: 14px; color: #475569; margin: 0;">
        <strong style="color: #0F172A">{total}</strong> {t('listing.count', { count: '' }).replace('{count}', '').trim()}
      </p>
    </div>
  </section>

  <section style="padding: 32px 24px; background: #F8FAFC;">
    <div style="max-width: 1280px; margin: 0 auto;">
      {vehicles.length === 0 ? (
        <div style="text-align: center; padding: 80px 0;">
          <i class="fa-solid fa-car-burst" style="font-size: 48px; color: #CBD5E1; margin-bottom: 16px"></i>
          <h2 style="font-size: 18px; font-weight: 700; color: #0F172A">{t('listing.empty.title')}</h2>
          <p style="font-size: 14px; color: #475569; margin-top: 4px">{t('listing.empty.subtitle')}</p>
        </div>
      ) : (
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;" class="lifestyle-list-grid">
          {vehicles.map((v: any) => <VehicleCard vehicle={v} />)}
        </div>
      )}
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @media (max-width: 1024px) { .lifestyle-list-grid { grid-template-columns: repeat(3, 1fr) !important; } }
  @media (max-width: 768px) { .lifestyle-list-grid { grid-template-columns: repeat(2, 1fr) !important; } }
  @media (max-width: 480px) { .lifestyle-list-grid { grid-template-columns: 1fr !important; } }
</style>

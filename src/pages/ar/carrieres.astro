---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
export const prerender = false;
---
<Layout title="الوظائف — بورصة">
  <Header />
  <section style="background: white; border-bottom: 1px solid #E2E8F0;" dir="rtl">
    <div style="max-width: 1400px; margin: 0 auto; padding: 32px 24px;">
      <h1 style="font-size: 28px; font-weight: 800; color: #0F172A; margin: 0 0 6px;">انضم إلى فريق بورصة</h1>
      <p style="font-size: 14px; color: #475569; margin: 0;">لنبني معاً مستقبل سوق السيارات في موريتانيا</p>
    </div>
  </section>
  
      <section style="background:white; padding:64px 24px;" dir="rtl">
        <div style="max-width:800px; margin:0 auto;">
          <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:12px; padding:32px; text-align:center; margin-bottom:48px;">
            <div style="font-size:40px; margin-bottom:12px;">🚀</div>
            <h2 style="font-size:20px; font-weight:800; color:#0F172A; margin:0 0 8px;">لا توجد وظائف شاغرة حالياً</h2>
            <p style="font-size:14px; color:#475569; margin:0 0 20px;">لكننا ننمو بسرعة. أرسل لنا طلب ترشح تلقائي.</p>
            <a href="/ar/contact" style="display:inline-block; background:#16A34A; color:white; padding:12px 28px; border-radius:8px; font-weight:700; text-decoration:none; font-size:14px;">ترشح تلقائي</a>
          </div>
          <h2 style="font-size:20px; font-weight:800; color:#0F172A; margin:0 0 20px;">لماذا تنضم إلى بورصة؟</h2>
          <div style="display:flex; flex-direction:column; gap:16px;">
            <div style="display:flex; gap:16px; align-items:flex-start;"><span style="font-size:24px;">🌍</span><div><div style="font-weight:700; color:#0F172A; margin-bottom:4px;">أثر حقيقي</div><p style="font-size:14px; color:#475569; margin:0; line-height:1.7;">ستعمل على منتج يستخدمه آلاف الموريتانيين كل شهر.</p></div></div>
            <div style="display:flex; gap:16px; align-items:flex-start;"><span style="font-size:24px;">💪</span><div><div style="font-weight:700; color:#0F172A; margin-bottom:4px;">مسؤوليات من اليوم الأول</div><p style="font-size:14px; color:#475569; margin:0; line-height:1.7;">فريق صغير = استقلالية كبيرة. قراراتك تهم.</p></div></div>
            <div style="display:flex; gap:16px; align-items:flex-start;"><span style="font-size:24px;">📈</span><div><div style="font-weight:700; color:#0F172A; margin-bottom:4px;">نمو سريع</div><p style="font-size:14px; color:#475569; margin:0; line-height:1.7;">شركة ناشئة في طور النمو — فرص التطور حقيقية.</p></div></div>
          </div>
        </div>
      </section>
    
  <Footer />
</Layout>

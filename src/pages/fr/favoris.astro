---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import FavoritesList from '@/components/FavoritesList';
import { getLang } from '@/i18n/translations';

export const prerender = false;
const lang = getLang(Astro.currentLocale);
---

<Layout title={lang === 'ar' ? 'مفضلتي' : 'Mes favoris'}>
  <Header />
  <main style="min-height: calc(100vh - 200px); background: #F8FAFC;">
    <FavoritesList client:load lang={lang} />
  </main>
  <Footer />
</Layout>

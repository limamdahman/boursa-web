---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import Categories from '@/components/Categories.astro';
import FeaturedVehicles from '@/components/FeaturedVehicles.astro';
import BrandsGrid from '@/components/BrandsGrid.astro';
import LifestyleGrid from '@/components/LifestyleGrid.astro';
import AgencyCTA from '@/components/AgencyCTA.astro';
import TrustBar from '@/components/TrustBar.astro';
import Footer from '@/components/Footer.astro';
import VehicleCard from '@/components/VehicleCard.astro';
import SubscriptionBanner from '@/components/SubscriptionBanner';
import PartnerAgencies from '@/components/PartnerAgencies';
import ChatBoursa from '@/components/ChatBoursa';
import RecentVehicles from '@/components/RecentVehicles';

import { listBrands, listCities, getFeaturedVehicles, listVehicles } from '@/lib/api';

export const prerender = false;

let brands: any[] = [];
let cities: any[] = [];
let featuredVehicles: any[] = [];
let total = 0;
let dealVehicles: any[] = [];

try {
  [brands, cities, featuredVehicles] = await Promise.all([
    listBrands().catch(() => []),
    listCities().catch(() => []),
    getFeaturedVehicles(5).catch(() => []),
  ]);

  const listing = await listVehicles({ per_page: 5 }).catch(() => null);
  total = listing?.meta?.total ?? featuredVehicles.length;
  const dealsData = await listVehicles({ is_deal: 1, per_page: 6 }).catch(() => null);
  dealVehicles = dealsData?.data ?? [];
} catch (err) {
  console.error('Erreur chargement:', err);
}
---

<Layout>
  <Header active="home" />
  <SubscriptionBanner client:load lang="fr" apiUrl={import.meta.env.PUBLIC_API_URL} />
  <Hero brands={brands} cities={cities} totalVehicles={total} />
  <PartnerAgencies client:load lang="fr" apiUrl={import.meta.env.PUBLIC_API_URL} />
  <Categories />
  {dealVehicles.length > 0 && (
    <section style="padding: 40px 24px; background: white;">
      <div style="max-width: 1400px; margin: 0 auto;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2H4a2 2 0 0 0-2 2v5.5L12.5 20a2 2 0 0 0 2.83 0l5.17-5.17a2 2 0 0 0 0-2.83Z"/><circle cx="7" cy="7" r="1.5" fill="#EF4444" stroke="none"/></svg>
          <h2 style="font-size: 20px; font-weight: 800; color: #0F172A; margin: 0;">Les meilleures affaires</h2>
          <span style="background: linear-gradient(135deg,#EF4444,#DC2626); color: white; font-size: 11px; font-weight: 900; padding: 3px 10px; border-radius: 100px;">Véhicules avec prix réduits</span>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px;">
          {dealVehicles.map(v => <VehicleCard vehicle={v} />)}
        </div>
      </div>
    </section>
  )}
  <FeaturedVehicles vehicles={featuredVehicles} total={total} />
  <RecentVehicles client:load lang="fr" apiUrl={import.meta.env.PUBLIC_API_URL} />
  <LifestyleGrid />
  <BrandsGrid />
  <AgencyCTA />
  <TrustBar />
  <ChatBoursa client:load lang="fr" apiUrl={import.meta.env.PUBLIC_API_URL} />
  <Footer />
</Layout>
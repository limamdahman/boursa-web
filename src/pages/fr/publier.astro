---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PublishWizard from '@/components/PublishWizard';
import { getLang } from '@/i18n/translations';

export const prerender = false;
const lang = getLang(Astro.currentLocale);
---

<Layout title={lang === 'ar' ? 'نشر إعلان' : 'Publier une annonce'}>
  <Header />
  <main style="min-height: calc(100vh - 200px); background: #F8FAFC; padding: 20px 0 60px;">
    <PublishWizard client:load lang={lang} />
  </main>
  <Footer />
</Layout>

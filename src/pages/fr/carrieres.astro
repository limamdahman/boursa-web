---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
export const prerender = false;
---
<Layout title="Carrières — Boursa">
  <Header />
  <section style="background: white; border-bottom: 1px solid #E2E8F0;">
    <div style="max-width: 1400px; margin: 0 auto; padding: 32px 24px;" dir="ltr">
      <h1 style="font-size: 28px; font-weight: 800; color: #0F172A; margin: 0 0 6px;">Rejoignez l'équipe Boursa</h1>
      <p style="font-size: 14px; color: #475569; margin: 0;">Construisons ensemble le futur du marché auto en Mauritanie</p>
    </div>
  </section>
  
      <section style="background:white; padding:64px 24px;">
        <div style="max-width:800px; margin:0 auto;">
          <div style="background:#F0FDF4; border:1px solid #BBF7D0; border-radius:12px; padding:32px; text-align:center; margin-bottom:48px;">
            <div style="font-size:40px; margin-bottom:12px;">🚀</div>
            <h2 style="font-size:20px; font-weight:800; color:#0F172A; margin:0 0 8px;">Pas de postes ouverts en ce moment</h2>
            <p style="font-size:14px; color:#475569; margin:0 0 20px;">Mais nous grandissons vite. Laissez-nous votre candidature spontanée.</p>
            <a href="/fr/contact" style="display:inline-block; background:#16A34A; color:white; padding:12px 28px; border-radius:8px; font-weight:700; text-decoration:none; font-size:14px;">
              Candidature spontanée
            </a>
          </div>
          <h2 style="font-size:20px; font-weight:800; color:#0F172A; margin:0 0 20px;">Pourquoi rejoindre Boursa ?</h2>
          <div style="display:flex; flex-direction:column; gap:16px;">
            <div style="display:flex; gap:16px; align-items:flex-start;">
              <span style="font-size:24px;">🌍</span>
              <div><div style="font-weight:700; color:#0F172A; margin-bottom:4px;">Impact réel</div><p style="font-size:14px; color:#475569; margin:0; line-height:1.6;">Vous travaillez sur un produit utilisé par des milliers de Mauritaniens chaque mois.</p></div>
            </div>
            <div style="display:flex; gap:16px; align-items:flex-start;">
              <span style="font-size:24px;">💪</span>
              <div><div style="font-weight:700; color:#0F172A; margin-bottom:4px;">Responsabilités dès le premier jour</div><p style="font-size:14px; color:#475569; margin:0; line-height:1.6;">Petite équipe = grande autonomie. Vos décisions comptent.</p></div>
            </div>
            <div style="display:flex; gap:16px; align-items:flex-start;">
              <span style="font-size:24px;">📈</span>
              <div><div style="font-weight:700; color:#0F172A; margin-bottom:4px;">Croissance rapide</div><p style="font-size:14px; color:#475569; margin:0; line-height:1.6;">Startup en croissance — les opportunités d'évolution sont réelles.</p></div>
            </div>
          </div>
        </div>
      </section>
    
  <Footer />
</Layout>

---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import EditVehicleWizard from '@/components/EditVehicleWizard';
import { getLang } from '@/i18n/translations';

export const prerender = false;
const lang = getLang(Astro.currentLocale);
const { id } = Astro.params;

if (!id) return Astro.redirect('/' + lang + '/mes-annonces');
---

<Layout title={lang === 'ar' ? 'تعديل الإعلان' : 'Modifier l\'annonce'}>
  <Header />
  <main style="min-height: calc(100vh - 200px); background: #F8FAFC; padding: 20px 0 60px;">
    <EditVehicleWizard client:load lang={lang} vehicleId={id} />
  </main>
  <Footer />
</Layout>

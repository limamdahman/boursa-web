---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import VehicleComparator from '@/components/VehicleComparator';
import { getLang } from '@/i18n/translations';
export const prerender = false;
const lang = getLang(Astro.currentLocale);
const ids = Astro.url.searchParams.get('ids') ?? '';
---
<Layout title={lang === 'ar' ? 'مقارنة السيارات' : 'Comparateur de véhicules'}>
  <Header />
  <main style="min-height: calc(100vh - 200px); background: #F8FAFC; padding: 24px 0 60px;">
    <VehicleComparator client:load ids={ids} lang={lang} apiUrl={import.meta.env.PUBLIC_API_URL} />
  </main>
  <Footer />
</Layout>

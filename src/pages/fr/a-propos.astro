---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
export const prerender = false;
---
<Layout title="À propos de Boursa">
  <Header />
  <section style="background: white; border-bottom: 1px solid #E2E8F0;">
    <div style="max-width: 1400px; margin: 0 auto; padding: 32px 24px;" dir="ltr">
      <h1 style="font-size: 28px; font-weight: 800; color: #0F172A; margin: 0 0 6px;">À propos de Boursa</h1>
      <p style="font-size: 14px; color: #475569; margin: 0;">La marketplace auto n°1 en Mauritanie</p>
    </div>
  </section>
  
      <section style="background:white; padding:64px 24px;">
        <div style="max-width:800px; margin:0 auto;">
          <h2 style="font-size:22px; font-weight:800; color:#0F172A; margin:0 0 16px;">Notre mission</h2>
          <p style="font-size:15px; color:#475569; line-height:1.8; margin:0 0 32px;">
            Boursa est la première plateforme dédiée à l'achat et la vente de véhicules en Mauritanie. Notre mission : rendre le marché automobile mauritanien transparent, accessible et sécurisé pour tous.
          </p>
          <h2 style="font-size:22px; font-weight:800; color:#0F172A; margin:0 0 16px;">Notre histoire</h2>
          <p style="font-size:15px; color:#475569; line-height:1.8; margin:0 0 32px;">
            Fondée à Nouakchott, Boursa est née d'un constat simple : le marché de l'occasion en Mauritanie manquait de transparence et de confiance. Nous avons bâti une plateforme qui connecte directement acheteurs et vendeurs, avec des annonces vérifiées et des agences certifiées.
          </p>
          <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin:40px 0;">
            <div style="background:#F0FDF4; border-radius:12px; padding:24px; text-align:center;">
              <div style="font-size:32px; font-weight:800; color:#16A34A;">12k+</div>
              <div style="font-size:13px; color:#475569; margin-top:4px;">Visiteurs / mois</div>
            </div>
            <div style="background:#F0FDF4; border-radius:12px; padding:24px; text-align:center;">
              <div style="font-size:32px; font-weight:800; color:#16A34A;">2 470</div>
              <div style="font-size:13px; color:#475569; margin-top:4px;">Annonces actives</div>
            </div>
            <div style="background:#F0FDF4; border-radius:12px; padding:24px; text-align:center;">
              <div style="font-size:32px; font-weight:800; color:#16A34A;">142</div>
              <div style="font-size:13px; color:#475569; margin-top:4px;">Agences partenaires</div>
            </div>
          </div>
          <h2 style="font-size:22px; font-weight:800; color:#0F172A; margin:0 0 16px;">Nos valeurs</h2>
          <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:16px;">
            <div style="border:1px solid #E2E8F0; border-radius:10px; padding:20px;">
              <div style="font-weight:700; color:#0F172A; margin-bottom:6px;">🔒 Confiance</div>
              <p style="font-size:14px; color:#475569; margin:0; line-height:1.6;">Chaque agence est vérifiée manuellement. Chaque annonce est contrôlée.</p>
            </div>
            <div style="border:1px solid #E2E8F0; border-radius:10px; padding:20px;">
              <div style="font-weight:700; color:#0F172A; margin-bottom:6px;">💡 Transparence</div>
              <p style="font-size:14px; color:#475569; margin:0; line-height:1.6;">Prix affichés clairement, historique visible, pas de frais cachés.</p>
            </div>
            <div style="border:1px solid #E2E8F0; border-radius:10px; padding:20px;">
              <div style="font-weight:700; color:#0F172A; margin-bottom:6px;">🇲🇷 100% Mauritanie</div>
              <p style="font-size:14px; color:#475569; margin:0; line-height:1.6;">Conçu pour le marché mauritanien, en français et en arabe.</p>
            </div>
            <div style="border:1px solid #E2E8F0; border-radius:10px; padding:20px;">
              <div style="font-weight:700; color:#0F172A; margin-bottom:6px;">⚡ Rapidité</div>
              <p style="font-size:14px; color:#475569; margin:0; line-height:1.6;">Publiez en 5 minutes. Vendez en 24h.</p>
            </div>
          </div>
        </div>
      </section>
    
  <Footer />
</Layout>
